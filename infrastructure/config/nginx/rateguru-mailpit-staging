# RateGuru staging — Mailpit web UI + API reverse proxy.
#
# Publishes ONLY the loopback Mailpit HTTP endpoint (127.0.0.1:8025) over
# HTTPS with Basic Auth. The SMTP port (1025) and the raw HTTP/API port
# (8025) are never exposed publicly by this vhost.

# WebSocket upgrade helper. Uniquely named so this vhost file stays
# self-contained and never collides with the mailtrap vhost's own map.
map $http_upgrade $mailpit_connection_upgrade {
    default upgrade;
    ''      close;
}

# Public HTTP endpoint: redirect visitors to HTTPS.
server {
    listen 80;
    listen [::]:80;

    server_name mailpit.rateguru.staging.myprojects.pp.ua;

    return 301 https://$host$request_uri;
}

# Public HTTPS endpoint.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name mailpit.rateguru.staging.myprojects.pp.ua;

    auth_basic "RateGuru staging mail capture";
    auth_basic_user_file /etc/nginx/rateguru-staging.htpasswd;

    access_log /var/log/nginx/rateguru-mailpit-staging-access.log;
    error_log /var/log/nginx/rateguru-mailpit-staging-error.log;

    client_max_body_size 32m;

    # Certbot-managed certificate (same layout as the primary staging vhost).
    ssl_certificate /etc/letsencrypt/live/mailpit.rateguru.staging.myprojects.pp.ua/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mailpit.rateguru.staging.myprojects.pp.ua/privkey.pem;

    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        # Proxy only to the loopback Mailpit HTTP/API listener.
        proxy_pass http://127.0.0.1:8025;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support for the live message stream (/api/events).
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $mailpit_connection_upgrade;
        proxy_read_timeout 3600s;
    }
}
