# Internal endpoint used only by local deployment health checks.
server {
    listen 80;
    listen [::]:80;

    server_name rateguru-staging.internal;

    allow 127.0.0.1;
    allow ::1;
    deny all;

    root /home/www/rateguru/staging/current/public;
    index index.php;

    access_log /var/log/nginx/rateguru-staging-internal-access.log;
    error_log /var/log/nginx/rateguru-staging-internal-error.log;

    client_max_body_size 64m;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;

        fastcgi_pass unix:/run/php/rateguru-staging.sock;

        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}

# Public HTTP endpoint: redirect visitors to HTTPS.
server {
    listen 80;
    listen [::]:80;

    server_name rateguru.staging.myprojects.pp.ua;

    return 301 https://$host$request_uri;
}

# Public HTTPS endpoint.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name rateguru.staging.myprojects.pp.ua;

    root /home/www/rateguru/staging/current/public;
    index index.php;

    access_log /var/log/nginx/rateguru-staging-access.log;
    error_log /var/log/nginx/rateguru-staging-error.log;

    client_max_body_size 64m;

    ssl_certificate /etc/letsencrypt/live/rateguru.staging.myprojects.pp.ua/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/rateguru.staging.myprojects.pp.ua/privkey.pem;

    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;

        fastcgi_pass unix:/run/php/rateguru-staging.sock;

        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_param HTTPS on;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
