# Mailpit configuration for the RateGuru staging mail-capture slice.
#
# This file is intentionally committed. It contains no secrets: only loopback
# bind addresses, retention limits, and the loopback relay target. It is
# installed to /etc/rateguru/mail-capture/mailpit.env and loaded by the
# rateguru-mailpit.service unit via EnvironmentFile=.
#
# Mailpit is the CANONICAL capture service: it always stores the local copy
# and then best-effort relays a mirror to Mailtrap Local. See the runbook
# infrastructure/runbooks/mail-capture.md for the mirror semantics.

# --- Persistent storage (SQLite) -------------------------------------------
# Lives inside the service state directory, which is the only writable path.
MP_DATABASE=/var/lib/rateguru-mail-capture/mailpit/mailpit.db

# --- Listeners: loopback only ----------------------------------------------
# SMTP submission endpoint used by Laravel staging.
MP_SMTP_BIND_ADDR=127.0.0.1:1025
# HTTP UI + REST API, fronted by Nginx (Basic Auth + TLS).
MP_UI_BIND_ADDR=127.0.0.1:8025

# --- Retention -------------------------------------------------------------
# Keep at most 5000 messages and discard anything older than 14 days.
MP_MAX_MESSAGES=5000
MP_MAX_AGE=14d

# --- Relay-all mirror to Mailtrap Local ------------------------------------
# Mailpit relays every stored message to the secondary Mailtrap Local SMTP
# listener on loopback. This file only enables relay-all and points at the
# companion mailpit-relay.yml, which defines the relay TARGET (host/port/auth
# and forward-smtp-errors: false, so relay failures never fail delivery).
MP_SMTP_RELAY_ALL=true
MP_SMTP_RELAY_CONFIG=/etc/rateguru/mail-capture/mailpit-relay.yml

# Quieter logs: keep informational relay/store chatter out of journald while
# still emitting warnings and relay errors.
MP_QUIET=true
