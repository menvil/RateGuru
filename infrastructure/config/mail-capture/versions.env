# Pinned mail-capture component versions.
#
# This file is intentionally committed. It contains no secrets: only the
# exact upstream release tags that the installer is allowed to download and
# verify. Never use "latest" and never bump a version without also updating
# the matching checksum file under checksums/.
#
# Consumed by:
#   - infrastructure/scripts/install-mail-capture
#   - infrastructure/scripts/verify-mail-capture
#   - infrastructure/scripts/status-mail-capture
MAILPIT_VERSION=1.30.5
MAILTRAP_LOCAL_VERSION=0.2.0
